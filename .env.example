APP_BASE_URL=http://localhost:3000

# Dashboard login
DASHBOARD_LOGIN_ID=admin
DASHBOARD_LOGIN_PASSWORD=
# Optional multi-login (comma format: id:pw,id2:pw2)
# DASHBOARD_LOGIN_ACCOUNTS=admin:changeme,ops:changeme2

# Meta Threads app credentials
THREADS_APP_ID=
THREADS_APP_SECRET=

# Naver Login OAuth (for cafe target account linking)
# callback URL example: https://app.sbusim.co.kr/api/auth/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional override; default is https://graph.threads.net
# THREADS_GRAPH_BASE_URL=https://graph.threads.net/v1.0

# Optional: topic auto-post generation via Perplexity
# AI provider: perplexity | gemini (omit to auto-detect by available key)
# CONTENT_AI_PROVIDER=gemini
PERPLEXITY_API_KEY=
# Optional: default sonar
# PERPLEXITY_MODEL=sonar
# Optional: default https://api.perplexity.ai/chat/completions
# PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
GEMINI_API_KEY=
# Optional: default gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash
# Optional custom endpoint including model path
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# Optional Telegram alert (auto-plan / publish errors)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional Investing RSS review automation (draft-only + manual publish)
# RSS_REVIEW_ENABLED=1
# RSS_REVIEW_INTERVAL_MINUTES=60
# RSS_REVIEW_MAX_DRAFTS=3
# RSS_REVIEW_TARGET_ACCOUNT_IDS=
# Optional AI auto-repair on publish/comment errors (runs only when errors happen)
# AUTO_REPAIR_ENABLED=1
# AUTO_REPAIR_MAX_ATTEMPTS=1
# AUTO_REPAIR_AI_PROVIDER=auto
# AUTO_REPAIR_AI_MODEL=gemini-2.0-flash
# Optional low-view alert (runs with insights sync job)
# LOW_VIEW_ALERT_THRESHOLD=100
# LOW_VIEW_ALERT_LOOKBACK_HOURS=48
# LOW_VIEW_ALERT_MIN_POSTS=4
# LOW_VIEW_ALERT_COOLDOWN_MINUTES=720

# Local infra
DATABASE_URL=postgresql://sbusim:sbusim@localhost:5432/sbusim?schema=public
REDIS_URL=redis://localhost:6379

# Supabase (market automation module)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Market data providers
# Trading Economics is paid; leave empty to disable snapshot/calendar jobs.
TE_API_KEY=
# Optional override
# TE_BASE_URL=https://api.tradingeconomics.com
# CFTC Socrata/Foundry endpoint (optional override)
# CFTC_SOCRATA_URL=https://publicreporting.cftc.gov/resource/kh3c-gbw2.json

# Cron security
CRON_SECRET=
# default source display in generated posts (1=include, 0=hide)
DEFAULT_INCLUDE_SOURCES=1

# 32-byte key for AES-256-GCM. Use base64 (recommended) or hex.
# Example (base64): openssl rand -base64 32
ENCRYPTION_KEY=
